# ─── Database ────────────────────────────────────────────────────────────────
# Local Postgres (Docker):
#   docker run --name midtnvball-db -e POSTGRES_USER=midtn -e POSTGRES_PASSWORD=password \
#              -e POSTGRES_DB=midtnvball -p 5432:5432 -d postgres:16
DATABASE_URL="postgresql://midtn:password@localhost:5432/midtnvball"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"

# ─── Gemini AI (Knowledge Base chat) ─────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
