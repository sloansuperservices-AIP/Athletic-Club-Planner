generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH & IDENTITY (NextAuth v5 compatible)
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  ADMIN
  COACH
  TEAM_MANAGER
  PARENT
  ATHLETE
}

// ============================================================
// ORG & USER
// ============================================================

model Org {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  teams         Team[]
  tournaments   Tournament[]
  sponsors      Sponsor[]
  articles      KnowledgeArticle[]
  announcements Announcement[]
  jobs          WorkPlayJob[]
  memberships   Membership[]
  athletes      Athlete[]
  auditLogs     AuditLog[]
  jobClaims     JobClaim[]
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orgId String?
  org   Org?    @relation(fields: [orgId], references: [id])
  role  Role    @default(ATHLETE)

  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
  guardianOf    Guardian[]
  auditLogs     AuditLog[]
  jobClaims     JobClaim[]
  creditEntries CreditLedgerEntry[]
  sentMessages  Message[]            @relation("SentMessages")
  articles      KnowledgeArticle[]   @relation("ArticleAuthor")
  announcements Announcement[]       @relation("AnnouncementAuthor")
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  orgId     String
  teamRole  String   @default("MEMBER") // HEAD_COACH | ASST_COACH | TEAM_MANAGER | PARENT | ATHLETE
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  org       Org      @relation(fields: [orgId], references: [id])

  @@unique([userId, teamId])
}

// ============================================================
// TEAMS & ATHLETES
// ============================================================

model Team {
  id          String   @id @default(cuid())
  orgId       String
  org         Org      @relation(fields: [orgId], references: [id])
  name        String
  slug        String
  ageGroup    String
  level       String?  // Gold | Blue | Silver
  headCoachId String?
  season      String?
  division    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members       Membership[]
  athletes      Athlete[]
  tournaments   TeamTournament[]
  scheduleItems ScheduleItem[]
  jobs          WorkPlayJob[]

  @@unique([orgId, slug])
}

model Athlete {
  id                  String    @id @default(cuid())
  orgId               String
  org                 Org       @relation(fields: [orgId], references: [id])
  teamId              String
  team                Team      @relation(fields: [teamId], references: [id])
  firstName           String
  lastName            String
  jerseyNumber        String?
  position            String?
  gradYear            Int?
  gpa                 Float?
  photoUrl            String?
  waiverSigned        Boolean   @default(false)
  waiverSignedAt      DateTime?
  medicalFormComplete Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  guardians Guardian[]
  stats     AthleteStat[]
  rsvps     Rsvp[]

  @@unique([teamId, jerseyNumber])
}

model Guardian {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  athleteId    String
  athlete      Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  relationship String   @default("Guardian")
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([userId, athleteId])
}

model AthleteStat {
  id         String   @id @default(cuid())
  athleteId  String
  athlete    Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  skill      String
  value      Float
  unit       String?
  recordedAt DateTime @default(now())
}

model ScheduleItem {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  title     String
  type      String   @default("PRACTICE") // PRACTICE | GAME | TOURNAMENT | MEETING | OTHER
  startAt   DateTime
  endAt     DateTime
  location  String?
  notes     String?  @db.Text
  // Live scoring
  homeScore Int?
  awayScore Int?
  opponent  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rsvps Rsvp[]
}

// RSVP for schedule items
model Rsvp {
  id             String       @id @default(cuid())
  scheduleItemId String
  scheduleItem   ScheduleItem @relation(fields: [scheduleItemId], references: [id], onDelete: Cascade)
  athleteId      String
  athlete        Athlete      @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  status         String       @default("PENDING") // YES | NO | MAYBE | PENDING
  note           String?
  respondedAt    DateTime?
  createdAt      DateTime     @default(now())

  @@unique([scheduleItemId, athleteId])
}

// ============================================================
// TOURNAMENTS & READINESS
// ============================================================

model Tournament {
  id                   String    @id @default(cuid())
  orgId                String
  org                  Org       @relation(fields: [orgId], references: [id])
  name                 String
  slug                 String
  venue                String?
  city                 String?
  state                String?
  startDate            DateTime
  endDate              DateTime
  registrationDeadline DateTime?
  hotelDeadline        DateTime?
  rosterDeadline       DateTime?
  sanctioningBody      String?
  entryFee             Float?
  notes                String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  teams TeamTournament[]
  jobs  WorkPlayJob[]

  @@unique([orgId, slug])
}

model TeamTournament {
  id           String     @id @default(cuid())
  teamId       String
  team         Team       @relation(fields: [teamId], references: [id])
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  notes        String?
  createdAt    DateTime   @default(now())

  checklist ChecklistItem[]

  @@unique([teamId, tournamentId])
}

model ChecklistItem {
  id               String         @id @default(cuid())
  teamTournamentId String
  teamTournament   TeamTournament @relation(fields: [teamTournamentId], references: [id], onDelete: Cascade)
  column           String         // REGISTRATION | ROSTER | HOTEL | CALENDAR | WORKPLAY | RIDESHARE | SPONSOR
  status           String         @default("TODO") // TODO | IN_PROGRESS | DONE | NA
  notes            String?        @db.Text
  completedById    String?
  completedAt      DateTime?
  updatedAt        DateTime       @updatedAt

  auditTrail AuditLog[] @relation("ChecklistAudit")

  @@unique([teamTournamentId, column])
}

// ============================================================
// WORKPLAY / DIBS JOB BOARD
// ============================================================

model WorkPlayJob {
  id           String      @id @default(cuid())
  orgId        String
  org          Org         @relation(fields: [orgId], references: [id])
  teamId       String?
  team         Team?       @relation(fields: [teamId], references: [id])
  tournamentId String?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])
  title        String
  description  String      @db.Text
  category     String      @default("GENERAL") // EVENT | MEDIA | FUNDRAISING | LOGISTICS | GENERAL
  pointValue   Float       @default(1.0)
  isActive     Boolean     @default(true)
  createdById  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  slots JobSlot[]
}

model JobSlot {
  id          String      @id @default(cuid())
  jobId       String
  job         WorkPlayJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  label       String      @default("Slot 1")
  claimedById String?
  claimedAt   DateTime?
  createdAt   DateTime    @default(now())

  claim      JobClaim?
  completion JobCompletion?
}

model JobClaim {
  id            String    @id @default(cuid())
  slotId        String    @unique
  slot          JobSlot   @relation(fields: [slotId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  orgId         String
  org           Org       @relation(fields: [orgId], references: [id])
  claimedAt     DateTime  @default(now())
  status        String    @default("CLAIMED") // CLAIMED | COMPLETED | RELEASED | NO_SHOW
  adminOverride Boolean   @default(false)
  releasedAt    DateTime?

  creditEntry CreditLedgerEntry?

  @@unique([userId, slotId])
}

model JobCompletion {
  id           String   @id @default(cuid())
  slotId       String   @unique
  slot         JobSlot  @relation(fields: [slotId], references: [id], onDelete: Cascade)
  completedAt  DateTime @default(now())
  verifiedById String?
  notes        String?
}

// Immutable ledger — never a mutable balance field
model CreditLedgerEntry {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  claimId          String?   @unique
  claim            JobClaim? @relation(fields: [claimId], references: [id])
  amount           Float     // 1.0 earned | negative = deduction
  reason           String
  adminGrantedById String?
  createdAt        DateTime  @default(now())
}

// ============================================================
// SPONSORS
// ============================================================

model Sponsor {
  id           String   @id @default(cuid())
  orgId        String
  org          Org      @relation(fields: [orgId], references: [id])
  name         String
  tierName     String?  // Platinum | Gold | Silver | Bronze
  amount       Float?
  status       String   @default("PROSPECT") // PROSPECT | ACTIVE | LAPSED | DECLINED
  logoUrl      String?
  website      String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  deliverables SponsorDeliverable[]
}

model SponsorDeliverable {
  id          String    @id @default(cuid())
  sponsorId   String
  sponsor     Sponsor   @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  description String
  dueDate     DateTime?
  completedAt DateTime?
  notes       String?
}

// ============================================================
// KNOWLEDGE BASE
// ============================================================

model KnowledgeArticle {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])
  title     String
  content   String   @db.Text
  category  String   @default("GENERAL")
  tags      String[]
  authorId  String
  author    User     @relation("ArticleAuthor", fields: [authorId], references: [id])
  published Boolean  @default(false)
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// COMMUNICATIONS
// ============================================================

model Announcement {
  id           String    @id @default(cuid())
  orgId        String
  org          Org       @relation(fields: [orgId], references: [id])
  title        String
  body         String    @db.Text
  targetTeamId String?
  authorId     String
  author       User      @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  isPinned     Boolean   @default(false)
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  recipientId String?
  subject     String?
  body        String   @db.Text
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id            String         @id @default(cuid())
  orgId         String
  org           Org            @relation(fields: [orgId], references: [id])
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  action        String
  entityType    String
  entityId      String?
  oldValue      String?
  newValue      String?
  ip            String?
  createdAt     DateTime       @default(now())

  checklistItemId String?
  checklistItem   ChecklistItem? @relation("ChecklistAudit", fields: [checklistItemId], references: [id])
}
